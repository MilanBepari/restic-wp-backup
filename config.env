# export path
export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

#############################################
# ENV VARIABLES
#############################################
export RESTIC_REPOSITORY="s3:https://s3.us-central-1.idrivee2.com/bucket-name/path"
export RESTIC_PASSWORD="password"
export AWS_ACCESS_KEY_ID="access_key"
export AWS_SECRET_ACCESS_KEY="secret_key"

#############################################
# VARIABLES
#############################################
SITE_NAME="website_url"
WP_USER="www-data"
WP_PATH="/wp/install/path"

# Telegram
TELEGRAM_TOKEN="telegram_bot_token"
TELEGRAM_CHAT_ID="telegram_chat_id"

# Retention Policy
KEEP_DAILY=7
KEEP_WEEKLY=4
KEEP_MONTHLY=6

# Log and temp dir
TMP_DIR="/opt/restic-wp-backup"
LOG_FILE="/var/log/restic-wordpress.log"

#############################################
# Exclude Directories
#############################################

EXCLUDE_DIRS=(
    # WordPress cache
    "$WP_PATH/wp-content/cache"
    "$WP_PATH/wp-content/uploads/cache"
    "$WP_PATH/wp-content/upgrade"
    "$WP_PATH/wp-content/litespeed"
    "$WP_PATH/wp-content/et-cache"
    "$WP_PATH/wp-content/w3tc-config"

    # Backup plugins
    "$WP_PATH/wp-content/ai1wm-backups"
    "$WP_PATH/wp-content/updraft"
    "$WP_PATH/wp-content/backups-dup-lite"
    "$WP_PATH/wp-content/duplicator"
    "$WP_PATH/wp-content/snapshots"
    "$WP_PATH/wp-content/wpvividbackups"
    "$WP_PATH/wp-content/backupbuddy_backups"
    "$WP_PATH/wp-content/blogvault"

    # Staging
    "$WP_PATH/wp-content/wp-staging"

    # Security
    "$WP_PATH/wp-content/uploads/sucuri"
)

#############################################
# Exclude File Patterns
#############################################

EXCLUDE_FILES=(
    "*.log"
    "*.tmp"
    "*.temp"
)